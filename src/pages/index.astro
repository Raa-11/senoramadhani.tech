---
import MainLayout from "~/layouts/MainLayout.astro";
import HeroCard from "~/components/bento/HeroCard.svelte";
import PortraitCard from "~/components/bento/PortraitCard.svelte";
import NowCard from "~/components/bento/NowCard.svelte";
import AboutCard from "~/components/bento/AboutCard.svelte";
import WorkCard from "~/components/bento/WorkCard.svelte";
import SkillsCard from "~/components/bento/SkillsCard.svelte";
import EduCard from "~/components/bento/EduCard.svelte";
import HeatmapCard from "~/components/bento/HeatmapCard.svelte";
import OSSListCard from "~/components/bento/OSSListCard.svelte";
import ReposCard from "~/components/bento/ReposCard.svelte";
import LogCard from "~/components/bento/LogCard.svelte";
import SignoffCard from "~/components/bento/SignoffCard.svelte";
---

<MainLayout seo={{ title: "Home" }} bento>
  <div
    id="top"
    class="grid gap-2.5"
    style="grid-template-columns: repeat(12, 1fr); grid-auto-rows: minmax(80px, auto);"
    transition:persist="bento-home"
  >
    <!-- Hero + Portrait -->
    <div
      class="col-span-12 row-span-2 md:col-span-8 md:row-span-3"
      style="min-height: 340px"
    >
      <HeroCard client:only="svelte" />
    </div>
    <div
      class="col-span-12 row-span-2 md:col-span-4 md:row-span-3"
      style="min-height: 340px"
    >
      <PortraitCard client:visible />
    </div>

    <!-- Now + About -->
    <div class="col-span-12 row-span-2 md:col-span-6">
      <NowCard client:only="svelte" />
    </div>
    <div class="col-span-12 row-span-2 md:col-span-6">
      <AboutCard client:visible />
    </div>

    <!-- Work -->
    <div class="col-span-12 row-span-3"><WorkCard client:only="svelte" /></div>

    <!-- Skills marquee -->
    <div class="col-span-12 flex items-center" style="min-height: 90px">
      <SkillsCard client:visible />
    </div>

    <!-- Edu + Heatmap -->
    <div class="col-span-12 row-span-2 md:col-span-4">
      <EduCard client:visible />
    </div>
    <div class="col-span-12 row-span-2 md:col-span-8">
      <HeatmapCard client:visible />
    </div>

    <!-- Repos + Contributions -->
    <div class="col-span-12 row-span-2 md:col-span-8">
      <ReposCard client:visible />
    </div>
    <div class="col-span-12 row-span-2 md:col-span-4">
      <OSSListCard client:visible />
    </div>

    <!-- Log + Signoff -->
    <div class="col-span-12 row-span-2 md:col-span-6">
      <LogCard client:only="svelte" />
    </div>
    <div class="col-span-12 row-span-2 md:col-span-6">
      <SignoffCard client:visible />
    </div>
  </div>
</MainLayout>
